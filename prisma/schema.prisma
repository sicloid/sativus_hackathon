generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── Provider (Hizmet Sağlayıcı/Hekim) ─────────────────────────────────────────
model Provider {
  id           String        @id @default(cuid())
  name         String
  type         String // KLINIK, KUAFÖR, vb.
  specialty    String?
  imageUrl     String?
  rating       Float         @default(0.0)
  address      String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  slots        Slot[]

  @@map("providers")
}

// ─── Slot (Randevu Saati) ────────────────────────────────────────────────────
model Slot {
  id          String       @id @default(cuid())
  providerId  String
  date        DateTime
  startTime   String
  endTime     String
  isBooked    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  appointment Appointment?
  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, date])
  @@map("slots")
}

// ─── Appointment (Randevu) ───────────────────────────────────────────────────
model Appointment {
  id          String   @id @default(cuid())
  providerId  String
  slotId      String   @unique
  status      String   @default("PENDING")
  petName     String
  petSpecies  String
  petAge      Int?
  ownerName   String
  ownerPhone  String?
  notes       String?
  aiDiagnosis String?
  aiAciliyet  String?
  aiHizmet    String?
  aiOzeti     String?
  examFee     Float?   @map("exam_fee")
  vetDiagnosis String? @map("vet_diagnosis")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  provider    Provider @relation(fields: [providerId], references: [id])
  slot        Slot     @relation(fields: [slotId], references: [id])

  @@index([providerId])
  @@map("appointments")
}

// ═══════════════════════════════════════════════════════════════════════════════
// EVCİL HAYVAN & SAĞLIK Modelleri
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Pet (Evcil Hayvan) ───────────────────────────────────────────────────────
model Pet {
  id       String  @id @default(cuid())
  userId   String  @map("user_id") // Supabase auth user (sahip)
  name     String
  species  String // Köpek, Kedi, Kuş...
  breed    String? // Cins
  age      Int?
  weight   Float?
  imageUrl String? @map("image_url")

  vaccinations  Vaccination[]
  prescriptions Prescription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("pets")
}

// ─── Vaccination (Aşı Kaydı) ─────────────────────────────────────────────────
model Vaccination {
  id       String    @id @default(cuid())
  petId    String    @map("pet_id")
  name     String // Kuduz, Karma, vb.
  date     DateTime
  nextDate DateTime? @map("next_date") // Sonraki aşı tarihi
  vetName  String?   @map("vet_name")
  notes    String?

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([petId])
  @@map("vaccinations")
}

// ─── Prescription (Reçete) ───────────────────────────────────────────────────
model Prescription {
  id         String  @id @default(cuid())
  petId      String  @map("pet_id")
  vetUserId  String  @map("vet_user_id") // Hekim supabase user id
  vetName    String  @map("vet_name")
  diagnosis  String?
  notes      String?
  totalPrice Float   @default(0) @map("total_price")

  items PrescriptionItem[]
  pet   Pet                @relation(fields: [petId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([petId])
  @@index([vetUserId])
  @@map("prescriptions")
}

// ─── PrescriptionItem (Reçete Kalemi) ────────────────────────────────────────
model PrescriptionItem {
  id             String  @id @default(cuid())
  prescriptionId String  @map("prescription_id")
  productId      String? @map("product_id") // Mağaza ürünüyle eşleşirse
  name           String
  dosage         String?
  quantity       Int     @default(1)
  price          Float   @default(0)

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])

  @@map("prescription_items")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAĞAZA (E-Ticaret) Modelleri
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Product (Ürün) ───────────────────────────────────────────────────────────
model Product {
  id            String  @id @default(cuid())
  name          String
  description   String
  price         Float
  imageUrl      String? @map("image_url")
  category      String
  stockQuantity Int     @default(0) @map("stock_quantity")

  orderItems        OrderItem[]
  prescriptionItems PrescriptionItem[]
  reviews           Review[]
  questions         ProductQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// ─── Review (Ürün Yorumu) ────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  rating    Int      @default(5)
  comment   String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_reviews")
}

// ─── ProductQuestion (Ürün Sorusu) ───────────────────────────────────────────
model ProductQuestion {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  userId       String   @map("user_id")
  userEmail    String   @map("user_email")
  questionText String   @map("question_text")
  answerText   String?  @map("answer_text")
  status       String   @default("pending") // pending, answered
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("product_questions")
}

// ─── Order (Sipariş) ──────────────────────────────────────────────────────────
model Order {
  id           String @id @default(cuid())
  userId       String @map("user_id")
  status       String @default("PENDING")
  totalPrice   Float  @map("total_price")
  shippingCost Float  @default(0) @map("shipping_cost")
  tax          Float  @default(0)

  fullName  String      @map("full_name")
  phone     String
  address   String
  city      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]

  @@index([userId])
  @@map("orders")
}

// ─── OrderItem (Sipariş Kalemi) ───────────────────────────────────────────────
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  productId   String?  @map("product_id")
  productName String?  @map("product_name")
  quantity    Int
  unitPrice   Float    @map("unit_price")
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── Address (Adres Defteri) ──────────────────────────────────────────────────
model Address {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  fullName    String   @map("full_name")
  phone       String
  fullAddress String   @map("full_address")
  city        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

// ─── Coupon (Kupon) ───────────────────────────────────────────────────────────
model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int      @map("discount_percent")
  description     String
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usedBy UsedCoupon[]

  @@map("coupons")
}

// ─── UsedCoupon (Kullanılmış Kupon) ──────────────────────────────────────────
model UsedCoupon {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  couponId  String   @map("coupon_id")
  orderId   String   @map("order_id")
  usedAt    DateTime @default(now()) @map("used_at")

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@unique([userId, couponId])
  @@map("used_coupons")
}
