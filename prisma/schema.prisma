generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Provider {
  id           String        @id @default(cuid())
  name         String
  type         String
  specialty    String?
  imageUrl     String?
  rating       Float         @default(0.0)
  address      String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  slots        Slot[]

  @@map("providers")
}

model Slot {
  id          String       @id @default(cuid())
  providerId  String
  date        DateTime
  startTime   String
  endTime     String
  isBooked    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  appointment Appointment?
  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, date])
  @@map("slots")
}

model Appointment {
  id          String   @id @default(cuid())
  providerId  String
  slotId      String   @unique
  status      String   @default("PENDING")
  petName     String
  petSpecies  String
  petAge      Int?
  ownerName   String
  ownerPhone  String?
  notes       String?
  aiDiagnosis String?
  aiAciliyet  String?
  aiHizmet    String?
  aiOzeti     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  provider    Provider @relation(fields: [providerId], references: [id])
  slot        Slot     @relation(fields: [slotId], references: [id])

  @@index([providerId])
  @@map("appointments")
}

