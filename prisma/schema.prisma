generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
}

// ─── Provider (Klinik / Kuaför Uzmanı) ───────────────────────────────────────
model Provider {
  id          String   @id @default(cuid())
  name        String
  type        String   // "CLINIC" veya "GROOMER"
  specialty   String?
  imageUrl    String?
  rating      Float    @default(0.0)
  address     String?
  phone       String?

  slots        Slot[]
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("providers")
}

// ─── Slot (Zaman Dilimi) ──────────────────────────────────────────────────────
model Slot {
  id         String   @id @default(cuid())
  providerId String
  date       DateTime
  startTime  String
  endTime    String
  isBooked   Boolean  @default(false)

  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  appointment Appointment?

  createdAt DateTime @default(now())

  @@index([providerId, date])
  @@map("slots")
}

// ─── Appointment (Randevu) ────────────────────────────────────────────────────
model Appointment {
  id         String   @id @default(cuid())
  providerId String
  slotId     String   @unique
  status     String   @default("PENDING")

  // Evcil Hayvan Bilgisi
  petName    String
  petSpecies String
  petAge     Int?
  ownerName  String
  ownerPhone String?
  notes      String?

  // AI Teşhis Sonuçları
  aiDiagnosis    String?
  aiAciliyet     String?
  aiHizmet       String?
  aiOzeti        String?

  provider Provider @relation(fields: [providerId], references: [id])
  slot     Slot     @relation(fields: [slotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@map("appointments")
}
