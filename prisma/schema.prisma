// ─── Pet (Evcil Hayvan) ───────────────────────────────────────────────────────
model Pet {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") // Supabase auth user (sahip)
  name      String
  species   String   // Köpek, Kedi, Kuş...
  breed     String?  // Cins
  age       Int?
  weight    Float?
  imageUrl  String?  @map("image_url")

  vaccinations  Vaccination[]
  prescriptions Prescription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("pets")
}

// ─── Vaccination (Aşı Kaydı) ─────────────────────────────────────────────────
model Vaccination {
  id        String    @id @default(cuid())
  petId     String    @map("pet_id")
  name      String    // Kuduz, Karma, vb.
  date      DateTime
  nextDate  DateTime? @map("next_date") // Sonraki aşı tarihi
  vetName   String?   @map("vet_name")
  notes     String?

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([petId])
  @@map("vaccinations")
}

