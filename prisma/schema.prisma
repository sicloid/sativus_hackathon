// ─── PetVerse · Rezervasyon & AI Teşhis Modülleri ────────────────────────────
// Prisma Schema — SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Provider (Klinik / Kuaför Uzmanı) ───────────────────────────────────────
// Hizmet sağlayıcıyı temsil eder.
// Birden fazla Slot ve Appointment'a sahip olabilir.
model Provider {
  id          String   @id @default(cuid())
  name        String                          // "Dr. Ayşe Kaya", "PetGroomer Studio"
  type        ServiceType                     // CLINIC | GROOMER
  specialty   String?                         // "Dermatoloji", "Saç Kesimi & Bakım"
  imageUrl    String?
  rating      Float    @default(0.0)
  address     String?
  phone       String?

  slots        Slot[]
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("providers")
}

// ─── Slot (Zaman Dilimi) ──────────────────────────────────────────────────────
// Provider'ın takvimindeki her bir randevu slotunu temsil eder.
// isBooked=false → kullanıcı alabilir; isBooked=true → kapandı.
model Slot {
  id         String   @id @default(cuid())
  providerId String
  date       DateTime                        // Tarih (gün bilgisi için kullanılır)
  startTime  String                          // "09:00" — HH:MM formatı
  endTime    String                          // "09:30"
  isBooked   Boolean  @default(false)

  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  appointment Appointment? // Bir slot, en fazla bir randevuya bağlı

  createdAt DateTime @default(now())

  @@index([providerId, date])               // Takvim sorguları için index
  @@map("slots")
}

// ─── Appointment (Randevu) ────────────────────────────────────────────────────
// Kullanıcının rezerve ettiği randevuyu tutar.
// AI ön teşhis sonuçları buraya JSON string olarak yazılır.
model Appointment {
  id         String            @id @default(cuid())
  providerId String
  slotId     String            @unique          // Her slot sadece 1 randevuya
  status     AppointmentStatus @default(PENDING)

  // ─── Evcil Hayvan Bilgisi ─────────────────────────────
  petName    String
  petSpecies String                             // "Köpek", "Kedi", "Kuş"...
  petAge     Int?                               // Yaş (yıl)
  ownerName  String
  ownerPhone String?
  notes      String?                            // Kullanıcının ek notu

  // ─── AI Teşhis Sonuçları ──────────────────────────────
  // Gemini'den dönen { aciliyet, tavsiye_edilen_hizmet, ai_ozeti } JSON string
  aiDiagnosis    String?                        // Ham JSON string
  aiAciliyet     String?                        // "Yüksek" | "Orta" | "Düşük"
  aiHizmet       String?                        // "Klinik" | "Kuaför"
  aiOzeti        String?                        // Kısa açıklama metni

  provider Provider @relation(fields: [providerId], references: [id])
  slot     Slot     @relation(fields: [slotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@map("appointments")
}

// ─── AI Teşhis Oturumu (Chat Geçmişi) ────────────────────────────────────────
// /ai-asistan sayfasındaki her sohbet oturumunu kaydeder.
// Kullanıcının geçmiş teşhis sohbetlerine ulaşmasını sağlar.
model DiagnosisSession {
  id           String   @id @default(cuid())
  petName      String?
  petSpecies   String?
  messages     String                           // JSON string — Message[] dizisi
  finalResult  String?                          // Son Gemini JSON çıktısı

  // Session'dan randevuya bağlantı (opsiyonel)
  appointmentId String?

  createdAt DateTime @default(now())

  @@map("diagnosis_sessions")
}

// ─── Enums ────────────────────────────────────────────────────────────────────
enum ServiceType {
  CLINIC    // Veteriner Kliniği
  GROOMER   // Evcil Hayvan Kuaförü
}

enum AppointmentStatus {
  PENDING    // Oluşturuldu, henüz onaylanmadı
  CONFIRMED  // Onaylandı
  CANCELLED  // İptal edildi
  COMPLETED  // Tamamlandı
}
